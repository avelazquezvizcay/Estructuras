{
  "name": "sec",
  "version": "0.0.0",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"ng serve --host 0.0.0.0\" \"node electron/server.js\"",
    "build": "ng build --base-href ./",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.7",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "better-sqlite3": "^12.9.0",
    "chart.js": "^4.5.1",
    "cors": "^2.8.6",
    "decimal.js": "^10.6.0",
    "express": "^5.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "rxjs": "~7.8.0",
    "tesseract.js": "^7.0.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "@electron/rebuild": "^3.7.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "build": {
    "appId": "com.sec.app",
    "productName": "SEC - Estructura de Costos",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/sec/browser/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/sec_icon.png"
    }
  }
}
